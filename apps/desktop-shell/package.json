{
  "name": "personal-ai-assistant-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "description": "Desktop shell for Personal AI Assistant",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.personalai.assistant",
    "productName": "Personal AI Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html"
    ],
    "win": {
      "target": ["nsis"]
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
